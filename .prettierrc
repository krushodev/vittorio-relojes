{
    "semi": true,
    "trailingComma": "es5",
    "singleQuote": true,
    "printWidth": 100,
    "tabWidth": 4,
    "useTabs": false,
    "bracketSpacing": true,
    "arrowParens": "avoid",
    "endOfLine": "lf",
    "quoteProps": "as-needed",
    "bracketSameLine": false,
    "proseWrap": "preserve",
    "htmlWhitespaceSensitivity": "css",
    "embeddedLanguageFormatting": "auto",
    "plugins": ["prettier-plugin-blade"],
    "overrides": [
        {
            "files": "*.blade.php",
            "options": {
                "parser": "blade",
                "printWidth": 120,
                "tabWidth": 2,
                "singleQuote": true
            }
        },
        {
            "files": "*.{js,jsx,ts,tsx}",
            "options": {
                "parser": "babel"
            }
        },
        {
            "files": "*.{css,scss,less}",
            "options": {
                "parser": "css"
            }
        },
        {
            "files": "*.html",
            "options": {
                "parser": "html"
            }
        }
    ]
}
